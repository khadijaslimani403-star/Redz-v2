local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local RemoveFruitRemote = Remotes:WaitForChild("RemoveFruitFunction")

local function requestFruitRemovalAndReset()
    local success = RemoveFruitRemote:InvokeServer() 
    
    if success then
        print("تم إرسال طلب إزالة الفاكهة بنجاح من الحساب الحالي.")
        
        local player = game.Players.LocalPlayer
        if player and player.Character then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.Health = 0
            end
        end
    else
        warn("فشل الطلب، ربما بسبب عدم توفر المال الكافي (50k) في الحساب الحالي.")
    end
end

requestFruitRemovalAndReset()
